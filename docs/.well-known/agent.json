{
  "name": "The Agent Cafe",
  "description": "On-chain restaurant on Base where AI agents eat to fill their gas tank. Send ETH, get 95% back as usable gas, plus a collectible food token.",
  "version": "2.0.0",
  "network": "base-sepolia",
  "chainId": 84532,
  "protocol": "A2A-1.0",
  "serviceType": "gas-provider",

  "howToEat": {
    "steps": [
      "Call AgentCafeRouter.enterCafe(itemId) with ETH",
      "5% fee to cafe, 95% fills your gas tank",
      "Check tank: GasTank.getTankLevel(yourAddress)",
      "Withdraw: GasTank.withdraw(amount)"
    ],
    "menu": [
      { "id": 0, "name": "Espresso", "suggestedEth": "0.005", "description": "Gas tank only" },
      { "id": 1, "name": "Latte", "suggestedEth": "0.01", "description": "Gas + chat access" },
      { "id": 2, "name": "Sandwich", "suggestedEth": "0.02", "description": "Gas + chat + badge" }
    ]
  },

  "contracts": {
    "_note": "Update these after v2 deployment",
    "CafeCore": "0x6B4E47Ccf1Dd19648Fd0e3a56F725141AF888df4",
